---
import NichoLayout from '../../layouts/NichoLayout.astro';
import NichoHero from '../../components/sections/NichoHero.astro';
import NichoChecklist from '../../components/sections/NichoChecklist.astro';
import NichoCTA from '../../components/sections/NichoCTA.astro';

const mensagemWpp = 'Olá! Sou professor/tenho um curso e gostaria de saber como a Marvin Sites pode melhorar minha presença digital.';

const itens = [
  'Apresentação do professor e da metodologia',
  'Cursos e aulas descritos com clareza',
  'Público-alvo e resultados esperados',
  'Depoimentos de alunos',
  'Preços e formas de pagamento visíveis',
  'Botão de inscrição ou contato pelo WhatsApp',
  'Agenda de turmas ou aulas disponíveis',
  'Formação e credenciais do professor',
  'SEO local para "professor de [matéria] em [cidade]"',
  'Perguntas frequentes sobre o curso',
];
---

<NichoLayout
  title="Site para Professores e Cursos | Marvin Sites"
  description="Quem entende rápido o curso tem mais chance de pedir informações. Um site para professores e cursos que apresenta a metodologia e converte visitantes em alunos."
  nicho="professores"
  nomeNicho="Professores e Cursos"
>
  <NichoHero
    nicho="professores"
    badge="Educação e cursos"
    headline="Quem entende rápido o que você ensina tem muito mais chance de se inscrever."
    subheadline="Professores e cursos que explicam bem a metodologia, os resultados e o perfil do aluno ideal convertem muito mais do que os que dependem só de indicação boca a boca."
    argumentoCentral="Quem entende rápido o curso tem mais chance de pedir informações."
    mensagemWpp={mensagemWpp}
    cor="bg-yellow-50 text-yellow-700"
  />

  <NichoChecklist itens={itens} titulo="O que sua página de curso vai ter" />

  <section class="bg-gelo py-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-petroleo mb-8 text-center">
        Por que professores e cursos precisam de site próprio?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { titulo: 'Credibilidade instantânea', texto: 'Um professor com site organizado parece mais sério e preparado do que um que só tem Instagram. O pai que está procurando reforço escolar prefere quem tem uma página profissional.' },
          { titulo: 'Menos explicação, mais inscrição', texto: 'Em vez de repetir a mesma explicação pelo WhatsApp toda vez, a página já explica tudo: metodologia, preço, horário. O aluno chega decidido.' },
          { titulo: 'Captação contínua', texto: 'O site trabalha por você nas madrugadas e fins de semana. Alguém pode se interessar às 23h e mandar mensagem — você vê de manhã.' },
        ].map((card) => (
          <div class="bg-white rounded-xl border border-nevoa p-6">
            <h3 class="font-semibold text-petroleo mb-2">{card.titulo}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{card.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <NichoCTA nicho="professores" nomeNicho="escola ou curso" mensagemWpp={mensagemWpp} />
</NichoLayout>
