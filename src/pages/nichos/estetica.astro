---
import NichoLayout from '../../layouts/NichoLayout.astro';
import NichoHero from '../../components/sections/NichoHero.astro';
import NichoChecklist from '../../components/sections/NichoChecklist.astro';
import NichoCTA from '../../components/sections/NichoCTA.astro';

const mensagemWpp = 'Olá! Trabalho com estética/beleza e gostaria de saber como a Marvin Sites pode melhorar minha presença digital.';

const itens = [
  'Apresentação dos serviços com fotos reais de resultados',
  'Antes e depois dos principais procedimentos',
  'Profissional e formações em destaque',
  'Listagem de tratamentos com descrição e público-alvo',
  'Agendamento direto pelo WhatsApp por serviço',
  'Depoimentos de clientes com resultados',
  'Localização e horários de atendimento',
  'Galeria de resultados fotogênicos',
  'SEO local para "esteticista em [cidade]"',
  'Link para Instagram integrado',
];
---

<NichoLayout
  title="Site para Esteticistas e Salões de Beleza | Marvin Sites"
  description="Estética e beleza são fotogênicos — mostre seus resultados. Uma página profissional para esteticistas e salões que converte visitantes em agendamentos pelo WhatsApp."
  nicho="estetica"
  nomeNicho="Estética e Beleza"
>
  <NichoHero
    nicho="estetica"
    badge="Estética e beleza"
    headline="Resultado fala mais alto que qualquer texto. Sua página precisa mostrar isso."
    subheadline="No setor de beleza, a decisão começa nos olhos. Quem encontra fotos reais, resultados claros e agendamento fácil chama muito antes de quem não tem nada disso."
    argumentoCentral="Seu cliente precisa ver para confiar antes de agendar."
    mensagemWpp={mensagemWpp}
    cor="bg-pink-50 text-pink-700"
  />

  <NichoChecklist itens={itens} titulo="O que sua página de estética vai ter" />

  <section class="bg-gelo py-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-petroleo mb-8 text-center">
        Por que profissionais de estética precisam de site próprio?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { titulo: 'Instagram não é suficiente', texto: 'Instagram mostra o feed, mas não organiza serviços, preços, localização e agendamento num único lugar. A página faz tudo isso e ainda aparece no Google.' },
          { titulo: 'Antes/depois converte', texto: 'O antes e depois é o argumento mais poderoso do setor. Com uma página estruturada, esse conteúdo trabalha por você 24 horas por dia.' },
          { titulo: 'Você decide sozinha', texto: 'Sem depender de equipe técnica. Qualquer atualização de serviço, preço ou foto — é só nos avisar e a gente cuida na manutenção mensal.' },
        ].map((card) => (
          <div class="bg-white rounded-xl border border-nevoa p-6">
            <h3 class="font-semibold text-petroleo mb-2">{card.titulo}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{card.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <NichoCTA nicho="estetica" nomeNicho="clínica de estética" mensagemWpp={mensagemWpp} />
</NichoLayout>
