---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import WhatsAppButton from '../../components/layout/WhatsAppButton.astro';
import CidadeHero from '../../components/sections/CidadeHero.astro';
import CidadeNichos from '../../components/sections/CidadeNichos.astro';
import CidadeCTA from '../../components/sections/CidadeCTA.astro';

const cidade = 'Guarujá';
const uf = 'SP';
const mensagemWpp = 'Olá! Tenho um negócio em Guarujá e gostaria de saber como a Marvin Sites pode melhorar minha presença digital.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Criação de site para pequenos negócios em Guarujá SP',
  provider: { '@type': 'LocalBusiness', name: 'Marvin Sites' },
  areaServed: { '@type': 'City', name: 'Guarujá', containedInPlace: { '@type': 'State', name: 'São Paulo' } },
  description: 'Sites e presença digital para pequenos negócios em Guarujá SP — pousadas, clínicas, estética, reformas e mais.',
};

const diferenciais = [
  {
    titulo: 'Turismo exige presença digital de qualidade',
    texto: 'Em Guarujá, quem aparece melhor no Google quando o turista pesquisa leva a vantagem. Pousadas, restaurantes, clínicas e serviços locais competem pela primeira impressão digital — e quem tem site profissional passa na frente de quem só tem Instagram ou perfil no Google Maps incompleto.',
  },
  {
    titulo: 'Reservas diretas, menos comissão para plataformas',
    texto: 'Negócios de hospedagem em Guarujá que têm site próprio conseguem receber reservas diretas via WhatsApp, sem pagar comissão ao Booking ou ao Airbnb em cada reserva. A diferença na margem ao longo do ano é significativa — especialmente em alta temporada.',
  },
  {
    titulo: 'Presença o ano inteiro, não só no verão',
    texto: 'No baixo verão e fora do feriado, quem aparece bem no Google para buscas como "pousada em Guarujá" ou "clínica estética no Guarujá" mantém movimento constante. Presença digital bem estruturada reduz a dependência de sazonalidade.',
  },
];

const faq = [
  {
    pergunta: 'Quanto custa criar um site para uma pousada ou negócio em Guarujá?',
    resposta: 'Os planos da Marvin Sites para negócios em Guarujá começam em R$ 897 (setup) + R$ 147/mês de manutenção para a Página Local Essencial. O plano mais completo tem setup de R$ 2.497 + R$ 247/mês e inclui mais páginas, portfólio de fotos e estrutura mais completa — ideal para pousadas e negócios de turismo. O diagnóstico é gratuito.',
  },
  {
    pergunta: 'O site vai aparecer quando turistas pesquisarem serviços em Guarujá?',
    resposta: 'Sim. Cada página é estruturada com SEO local: palavras-chave como "Guarujá SP", nome dos bairros e praias (Pitangueiras, Enseada, Astúrias, Pernambuco), Schema.org para o Google entender a localização e o tipo de negócio. O resultado em buscas leva de semanas a alguns meses, mas a fundação técnica está correta desde o primeiro dia.',
  },
  {
    pergunta: 'Consigo receber reservas diretas pelo site sem pagar comissão?',
    resposta: 'Sim. O site inclui botão de WhatsApp em destaque para contato direto. A pousada ou o negócio negocia diretamente com o hóspede ou cliente, sem intermediário e sem comissão. Para hospedagens, também incluímos formulário de contato e instruções de como integrar com um sistema de reservas simples, se necessário.',
  },
  {
    pergunta: 'Atende clínicas, salões e prestadores de serviço no Guarujá?',
    resposta: 'Sim. Além de pousadas e turismo, atendemos clínicas de estética, consultórios, salões de beleza, empresas de reforma e qualquer prestador de serviço local. O site é adaptado ao tipo de negócio — não é um template genérico.',
  },
  {
    pergunta: 'Em quanto tempo o site fica pronto para um negócio em Guarujá?',
    resposta: 'O prazo padrão é de 7 dias úteis após o recebimento completo das informações e materiais. O processo é 100% remoto — você envia fotos, textos e informações do negócio pelo WhatsApp, e a entrega acontece dentro do prazo sem necessidade de reunião presencial.',
  },
];
---

<BaseLayout
  title="Criação de Site para Pequenos Negócios em Guarujá SP | Marvin Sites"
  description="Sites profissionais para pequenos negócios em Guarujá SP. Pousadas, clínicas, estética, reformas e mais. Entrega em 7 dias úteis. Diagnóstico gratuito."
  canonical="https://marvinsites.com.br/cidades/guaruja"
  {schema}
>
  <Header />
  <main>
    <CidadeHero
      {cidade} {uf}
      descricaoCidade="Guarujá recebe turistas e moradores que pesquisam tudo no celular — pousadas, clínicas, serviços locais. A Marvin Sites cria páginas profissionais para que negócios no Guarujá apareçam bem nessa busca, transmitam confiança e recebam contatos diretos pelo WhatsApp, sem depender de plataformas com comissão."
      {mensagemWpp}
    />

    <!-- Diferenciais locais -->
    <section class="bg-white py-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-petroleo mb-8 text-center">
          Por que a Marvin Sites para negócios em Guarujá?
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {diferenciais.map((d) => (
            <div class="bg-gelo rounded-xl border border-nevoa p-6">
              <h3 class="font-semibold text-petroleo mb-2">{d.titulo}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{d.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CidadeNichos {cidade} />

    <!-- Bairros atendidos -->
    <section class="bg-gelo py-12 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-xl font-semibold text-petroleo mb-4 text-center">Atendemos em todos os bairros do Guarujá</h2>
        <p class="text-gray-500 text-sm leading-relaxed max-w-3xl mx-auto text-center mb-6">
          Pitangueiras, Enseada, Astúrias, Pernambuco, Santa Cruz dos Navegantes, Jardim Virgínia, Perequê, Morrinhos, Tombo, Iporanga, Praia da Enseada, Praia de Pernambuco, Balneário Praia do Perequê e toda a região da ilha.
        </p>
        <p class="text-gray-500 text-sm leading-relaxed max-w-3xl mx-auto text-center">
          O atendimento é remoto e funciona para qualquer bairro do Guarujá. Você envia as informações do negócio pelo WhatsApp e o site fica pronto em até 7 dias úteis.
        </p>
      </div>
    </section>

    <!-- FAQ local -->
    <section class="bg-white py-16 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-petroleo mb-8 text-center">
          Dúvidas frequentes — negócios em Guarujá SP
        </h2>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="group bg-gelo rounded-xl border border-nevoa overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer font-medium text-petroleo text-sm list-none">
                {item.pergunta}
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <p class="px-5 pb-5 text-gray-500 text-sm leading-relaxed">{item.resposta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CidadeCTA {cidade} {mensagemWpp} />
  </main>
  <Footer />
  <WhatsAppButton origem="cidade-guaruja" />
</BaseLayout>
