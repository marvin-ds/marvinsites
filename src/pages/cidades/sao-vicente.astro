---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import WhatsAppButton from '../../components/layout/WhatsAppButton.astro';
import CidadeHero from '../../components/sections/CidadeHero.astro';
import CidadeNichos from '../../components/sections/CidadeNichos.astro';
import CidadeCTA from '../../components/sections/CidadeCTA.astro';

const cidade = 'São Vicente';
const uf = 'SP';
const mensagemWpp = 'Olá! Tenho um negócio em São Vicente e gostaria de saber como a Marvin Sites pode melhorar minha presença digital.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Criação de site para pequenos negócios em São Vicente SP',
  provider: { '@type': 'LocalBusiness', name: 'Marvin Sites' },
  areaServed: { '@type': 'City', name: 'São Vicente', containedInPlace: { '@type': 'State', name: 'São Paulo' } },
  description: 'Sites e presença digital para pequenos negócios em São Vicente SP — clínicas, contadores, estética, reformas e mais.',
};

const diferenciais = [
  {
    titulo: 'Cidade com tradição e mercado próprio',
    texto: 'São Vicente é a cidade mais antiga do Brasil, com um comércio local consolidado e mais de 360 mil habitantes. Negócios estabelecidos aqui precisam de presença digital à altura da sua reputação — e negócios novos precisam aparecer antes dos concorrentes que já dominam o bairro.',
  },
  {
    titulo: 'Clientes vicentinos pesquisam na própria cidade',
    texto: 'Moradores de São Vicente pesquisam por serviços na própria cidade antes de ir a Santos. Buscas como "clínica de estética em São Vicente", "contador em São Vicente SP" ou "empresa de reforma no Itararé" são feitas todo dia. Uma página otimizada para essas buscas captura exatamente esse público local.',
  },
  {
    titulo: 'Diferencial competitivo real agora',
    texto: 'Muitos negócios vicentinos ainda não têm site ou têm uma presença fraca. Quem investe agora em presença digital sai na frente de forma clara e mensurável — antes que os concorrentes percebam o que estão perdendo.',
  },
];

const faq = [
  {
    pergunta: 'Quanto custa criar um site para um negócio em São Vicente SP?',
    resposta: 'Os planos da Marvin Sites para negócios em São Vicente começam em R$ 897 (setup) + R$ 147/mês de manutenção para a Página Local Essencial. O plano mais completo tem setup de R$ 2.497 + R$ 247/mês. O diagnóstico para entender qual plano faz sentido para o seu negócio é gratuito e sem compromisso.',
  },
  {
    pergunta: 'O site vai aparecer no Google quando pesquisarem serviços em São Vicente?',
    resposta: 'Sim. Cada página é estruturada com SEO local específico para São Vicente: palavras-chave da cidade, bairros atendidos (Centro, Itararé, Gonzaguinha, Japuí, Jarivatuba, Vila Valença, Parque Bitaru, Catiapoa, Ilha Porchat e outros), e Schema.org para que o Google entenda o tipo de negócio e a localização. O posicionamento no Google leva de semanas a meses, mas a fundação técnica está correta desde o primeiro dia.',
  },
  {
    pergunta: 'Em quanto tempo o site fica pronto para um negócio em São Vicente?',
    resposta: 'O prazo padrão é de 7 dias úteis após o recebimento completo das informações e materiais (fotos, textos, logo). O processo é 100% remoto — você envia tudo pelo WhatsApp e o site é entregue dentro do prazo, sem necessidade de deslocamento ou reunião presencial.',
  },
  {
    pergunta: 'Meu negócio em São Vicente já tem muitos clientes por indicação. Preciso de site?',
    resposta: 'Clientes que chegam por indicação também pesquisam antes de ligar. Mesmo quando alguém indica um serviço em São Vicente, a primeira coisa que o indicado faz é pesquisar no Google para confirmar que é um negócio sério. Um site bem feito converte essa pesquisa em contato — e um negócio sem site ou com presença fraca perde essa confirmação para um concorrente.',
  },
  {
    pergunta: 'Atende qualquer tipo de negócio em São Vicente?',
    resposta: 'Sim. Clínicas, contadores, empresas de reforma, salões de beleza, professores particulares, consultórios, prestadores de serviço e pequenos comércios em São Vicente. O site é construído especificamente para o tipo de negócio — não é um template genérico aplicado a qualquer segmento.',
  },
];
---

<BaseLayout
  title="Criação de Site para Pequenos Negócios em São Vicente SP | Marvin Sites"
  description="Sites profissionais para pequenos negócios em São Vicente SP. Clínicas, contadores, estética, reformas e mais. Entrega em 7 dias úteis. Diagnóstico gratuito."
  canonical="https://marvinsites.com.br/cidades/sao-vicente"
  {schema}
>
  <Header />
  <main>
    <CidadeHero
      {cidade} {uf}
      descricaoCidade="São Vicente tem um mercado local ativo e clientes que pesquisam no Google antes de contratar qualquer serviço. A Marvin Sites cria páginas profissionais para que negócios vicentinos apareçam bem nessa busca, transmitam confiança e recebam contatos pelo WhatsApp — sem depender só de indicação."
      {mensagemWpp}
    />

    <!-- Diferenciais locais -->
    <section class="bg-white py-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-petroleo mb-8 text-center">
          Por que a Marvin Sites para negócios em São Vicente?
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {diferenciais.map((d) => (
            <div class="bg-gelo rounded-xl border border-nevoa p-6">
              <h3 class="font-semibold text-petroleo mb-2">{d.titulo}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{d.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CidadeNichos {cidade} />

    <!-- Bairros atendidos -->
    <section class="bg-gelo py-12 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-xl font-semibold text-petroleo mb-4 text-center">Atendemos em todos os bairros de São Vicente</h2>
        <p class="text-gray-500 text-sm leading-relaxed max-w-3xl mx-auto text-center mb-6">
          Centro, Itararé, Gonzaguinha, Japuí, Jarivatuba, Vila Valença, Parque Bitaru, Catiapoa, Vila São Jorge, Rio Branco, Ilha Porchat, Quarentenário, Vila São Paulo, Humaitá, Amador Bueno e toda a região continental e da ilha.
        </p>
        <p class="text-gray-500 text-sm leading-relaxed max-w-3xl mx-auto text-center">
          O atendimento é 100% remoto. Você envia as informações do negócio pelo WhatsApp e o site fica pronto em até 7 dias úteis — sem necessidade de reunião presencial.
        </p>
      </div>
    </section>

    <!-- FAQ local -->
    <section class="bg-white py-16 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold text-petroleo mb-8 text-center">
          Dúvidas frequentes — negócios em São Vicente SP
        </h2>
        <div class="space-y-3">
          {faq.map((item) => (
            <details class="group bg-gelo rounded-xl border border-nevoa overflow-hidden">
              <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer font-medium text-petroleo text-sm list-none">
                {item.pergunta}
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <p class="px-5 pb-5 text-gray-500 text-sm leading-relaxed">{item.resposta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CidadeCTA {cidade} {mensagemWpp} />
  </main>
  <Footer />
  <WhatsAppButton origem="cidade-sao-vicente" />
</BaseLayout>
