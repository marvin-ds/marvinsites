---
import DiagnosticForm from '../ui/DiagnosticForm.astro';
import Button from '../ui/Button.astro';
import { LINKS } from '../../lib/whatsapp';
---

<section id="contato" class="bg-petroleo py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Copy -->
    <div class="text-white">
      <span class="text-xs font-medium text-conversao uppercase tracking-widest">Diagnóstico gratuito</span>
      <h2 class="text-3xl sm:text-4xl font-bold mt-3 leading-tight mb-5">
        Seu negócio aparece bem quando o cliente pesquisa no Google?
      </h2>
      <p class="text-white/60 leading-relaxed mb-8">
        Preencha o formulário e a gente avalia sua presença digital em até 24 horas. Sem compromisso. Se fizer sentido para você, a gente conversa sobre os próximos passos.
      </p>

      <!-- Garantias -->
      <div class="space-y-3 text-sm">
        {[
          'Diagnóstico entregue em até 24 horas',
          'Sem compromisso de contratação',
          'Site de exemplo criado para o seu nicho',
          'Atendimento direto pelo WhatsApp',
        ].map((item) => (
          <div class="flex items-center gap-3 text-white/70">
            <div class="w-5 h-5 rounded-full bg-resultado/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-resultado" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            {item}
          </div>
        ))}
      </div>

      <div class="mt-8 pt-8 border-t border-white/10">
        <p class="text-white/40 text-sm mb-3">Prefere chamar direto?</p>
        <Button href={LINKS.cta_final} variant="whatsapp" target="_blank" rel="noopener noreferrer">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.849L.057 23.882a.5.5 0 0 0 .614.612l6.163-1.484A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.866 9.866 0 0 1-5.031-1.378l-.36-.214-3.733.899.934-3.634-.235-.374A9.866 9.866 0 0 1 2.106 12C2.106 6.533 6.533 2.106 12 2.106S21.894 6.533 21.894 12 17.467 21.894 12 21.894z"/>
          </svg>
          Chamar no WhatsApp agora
        </Button>
      </div>
    </div>

    <!-- Formulário -->
    <div class="bg-white rounded-2xl p-8">
      <h3 class="text-lg font-semibold text-petroleo mb-6">Solicitar diagnóstico gratuito</h3>
      <DiagnosticForm />
    </div>

  </div>
</section>
