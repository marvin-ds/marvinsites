---
const nichos = [
  { slug: 'clinicas',    label: 'Clínicas e Consultórios', cor: 'bg-blue-50 text-confianca' },
  { slug: 'contadores',  label: 'Contadores',              cor: 'bg-orange-50 text-orange-700' },
  { slug: 'reformas',    label: 'Reformas e Construção',   cor: 'bg-green-50 text-resultado' },
  { slug: 'estetica',    label: 'Estética e Beleza',       cor: 'bg-pink-50 text-pink-700' },
  { slug: 'turismo',     label: 'Turismo e Hospedagem',    cor: 'bg-purple-50 text-purple-700' },
  { slug: 'professores', label: 'Professores e Cursos',    cor: 'bg-yellow-50 text-yellow-700' },
];
---

<section id="exemplos" class="bg-gelo py-20 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-12">
      <span class="text-xs font-medium text-confianca uppercase tracking-widest">Exemplos</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-petroleo mt-3 leading-tight">
        Veja como fica para o seu segmento
      </h2>
      <p class="text-gray-500 mt-4 max-w-lg mx-auto">
        Clique no seu segmento e veja um exemplo real de como sua presença digital poderia ser.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {nichos.map((nicho) => (
        <a
          href={`/nichos/${nicho.slug}`}
          class="group bg-white rounded-xl border border-nevoa p-6 flex flex-col items-center text-center hover:border-confianca hover:shadow-md transition-all duration-200"
        >
          <div class={`w-12 h-12 rounded-xl ${nicho.cor} flex items-center justify-center mb-3 text-xl`}>
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253"/>
            </svg>
          </div>
          <span class="text-sm font-medium text-petroleo group-hover:text-confianca transition-colors">
            {nicho.label}
          </span>
        </a>
      ))}
    </div>

  </div>
</section>
