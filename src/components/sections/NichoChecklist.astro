---
interface Props {
  itens: string[];
  titulo?: string;
}

const { itens, titulo = 'O que sua página vai ter' } = Astro.props;
---

<section class="bg-white py-16 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto">

    <h2 class="text-2xl sm:text-3xl font-bold text-petroleo mb-8 text-center">{titulo}</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {itens.map((item) => (
        <div class="flex items-start gap-3 p-4 bg-gelo rounded-xl border border-nevoa">
          <div class="w-5 h-5 rounded-full bg-resultado/20 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-resultado" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-grafite text-sm leading-relaxed">{item}</span>
        </div>
      ))}
    </div>

  </div>
</section>
