---
import Button from '../ui/Button.astro';
import { gerarLinkWhatsApp, WHATSAPP_NUMERO } from '../../lib/whatsapp';

interface Props {
  cidade: string;
  mensagemWpp: string;
}

const { cidade, mensagemWpp } = Astro.props;

const linkWpp = gerarLinkWhatsApp({
  numero: WHATSAPP_NUMERO,
  mensagem: mensagemWpp,
  origem: `cta-cidade-${cidade.toLowerCase().replace(/ /g, '-')}`,
});
---

<section class="bg-petroleo py-16 px-4 sm:px-6">
  <div class="max-w-3xl mx-auto text-center text-white">

    <h2 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">
      Seu negócio em {cidade} merece aparecer melhor no Google.
    </h2>
    <p class="text-white/60 leading-relaxed mb-8 max-w-xl mx-auto">
      Diagnóstico gratuito, sem compromisso. A gente avalia sua presença atual e mostra exatamente o que pode melhorar.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
      <Button href={linkWpp} variant="whatsapp" size="lg" target="_blank" rel="noopener noreferrer">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.849L.057 23.882a.5.5 0 0 0 .614.612l6.163-1.484A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.866 9.866 0 0 1-5.031-1.378l-.36-.214-3.733.899.934-3.634-.235-.374A9.866 9.866 0 0 1 2.106 12C2.106 6.533 6.533 2.106 12 2.106S21.894 6.533 21.894 12 17.467 21.894 12 21.894z"/>
        </svg>
        Falar pelo WhatsApp agora
      </Button>
      <Button href="/#contato" variant="ghost" size="lg" class="border-white/30 text-white hover:bg-white/10 hover:text-white">
        Preencher formulário
      </Button>
    </div>

    <p class="text-white/30 text-xs">
      Atendimento em {cidade} e região · Entrega em até 7 dias úteis · Sem contrato longo
    </p>

  </div>
</section>
