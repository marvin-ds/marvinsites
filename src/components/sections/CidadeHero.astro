---
import Button from '../ui/Button.astro';
import { gerarLinkWhatsApp, WHATSAPP_NUMERO } from '../../lib/whatsapp';

interface Props {
  cidade: string;
  uf: string;
  descricaoCidade: string;
  mensagemWpp: string;
}

const { cidade, uf, descricaoCidade, mensagemWpp } = Astro.props;

const linkWpp = gerarLinkWhatsApp({
  numero: WHATSAPP_NUMERO,
  mensagem: mensagemWpp,
  origem: `hero-cidade-${cidade.toLowerCase().replace(' ', '-')}`,
});
---

<section class="bg-gelo pt-16 pb-20 px-4 sm:px-6">
  <div class="max-w-4xl mx-auto text-center">

    <nav class="flex justify-center items-center gap-2 text-xs text-gray-400 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-confianca transition-colors">Início</a>
      <span>/</span>
      <span class="text-grafite">{cidade}</span>
    </nav>

    <span class="inline-flex items-center gap-2 bg-blue-50 text-confianca text-xs font-medium px-3 py-1 rounded-full mb-6">
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
      </svg>
      {cidade}, {uf}
    </span>

    <h1 class="text-4xl sm:text-5xl font-bold text-petroleo leading-tight tracking-tight mb-5">
      Criação de site para pequenos negócios em {cidade}
    </h1>

    <p class="text-lg text-gray-500 leading-relaxed mb-4 max-w-2xl mx-auto">
      {descricaoCidade}
    </p>

    <p class="text-sm text-gray-400 mb-10">
      Atendemos negócios em {cidade} e região com entrega em até 7 dias úteis.
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <Button href={linkWpp} variant="primary" size="lg" target="_blank" rel="noopener noreferrer">
        Quero um site para meu negócio em {cidade}
      </Button>
      <Button href="/#servicos" variant="ghost" size="lg">
        Ver planos e preços
      </Button>
    </div>

  </div>
</section>
