---
---

<form
  name="diagnostico"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/obrigado"
  class="space-y-4"
  id="form-diagnostico"
>
  <!-- Honeypot anti-bot -->
  <input type="hidden" name="form-name" value="diagnostico" />
  <p class="hidden"><label>Não preencha: <input name="bot-field" /></label></p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="nome" class="block text-sm font-medium text-grafite mb-1">Seu nome</label>
      <input
        type="text"
        id="nome"
        name="nome"
        required
        autocomplete="name"
        placeholder="Maria Silva"
        class="w-full px-4 py-3 rounded-lg border border-nevoa bg-white text-grafite placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-confianca text-sm"
      />
    </div>
    <div>
      <label for="whatsapp" class="block text-sm font-medium text-grafite mb-1">WhatsApp</label>
      <input
        type="tel"
        id="whatsapp"
        name="whatsapp"
        required
        autocomplete="tel"
        placeholder="(13) 99999-9999"
        class="w-full px-4 py-3 rounded-lg border border-nevoa bg-white text-grafite placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-confianca text-sm"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="cidade" class="block text-sm font-medium text-grafite mb-1">Cidade</label>
      <input
        type="text"
        id="cidade"
        name="cidade"
        required
        placeholder="Santos, SP"
        class="w-full px-4 py-3 rounded-lg border border-nevoa bg-white text-grafite placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-confianca text-sm"
      />
    </div>
    <div>
      <label for="segmento" class="block text-sm font-medium text-grafite mb-1">Segmento do negócio</label>
      <select
        id="segmento"
        name="segmento"
        required
        class="w-full px-4 py-3 rounded-lg border border-nevoa bg-white text-grafite focus:outline-none focus:ring-2 focus:ring-confianca text-sm"
      >
        <option value="" disabled selected>Selecione...</option>
        <option>Clínica / Consultório</option>
        <option>Contador / Consultoria</option>
        <option>Reforma / Construção</option>
        <option>Estética / Beleza</option>
        <option>Professor / Curso</option>
        <option>Turismo / Hospedagem</option>
        <option>Restaurante / Delivery</option>
        <option>Imobiliária / Corretor</option>
        <option>Serviços automotivos</option>
        <option>Outro</option>
      </select>
    </div>
  </div>

  <!-- Consentimento LGPD obrigatório -->
  <label class="flex items-start gap-3 cursor-pointer">
    <input
      type="checkbox"
      name="consentimento"
      required
      class="mt-0.5 w-4 h-4 accent-confianca flex-shrink-0"
    />
    <span class="text-xs text-gray-500 leading-relaxed">
      Concordo com a
      <a href="/privacidade" class="underline hover:text-confianca">Política de Privacidade</a>
      e autorizo o contato pelo WhatsApp informado.
    </span>
  </label>

  <button
    type="submit"
    class="w-full bg-conversao text-white font-semibold py-4 rounded-lg hover:bg-orange-600 transition-colors text-sm tracking-wide"
  >
    Solicitar diagnóstico gratuito
  </button>
</form>
