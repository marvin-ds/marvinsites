---
const ano = new Date().getFullYear();
---

<footer class="bg-petroleo text-white/70 text-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">

    <!-- Marca -->
    <div>
      <div class="flex items-center gap-2 mb-3">
        <img src="/logo-mark.png" alt="" class="h-7 w-7 rounded-lg object-cover" width="28" height="28" aria-hidden="true" />
        <span class="text-white font-semibold">Marvin <span class="text-confianca">Sites</span></span>
      </div>
      <p class="text-white/70 leading-relaxed text-xs max-w-xs">
        Sites e presença digital para pequenos negócios locais serem encontrados, transmitirem confiança e receberem contatos pelo WhatsApp.
      </p>
    </div>

    <!-- Links -->
    <div>
      <p class="text-white/70 uppercase text-xs font-medium tracking-wider mb-3">Nichos</p>
      <ul class="space-y-2">
        <li><a href="/nichos/clinicas"    class="hover:text-white transition-colors">Clínicas e Consultórios</a></li>
        <li><a href="/nichos/contadores"  class="hover:text-white transition-colors">Contadores e Consultorias</a></li>
        <li><a href="/nichos/reformas"    class="hover:text-white transition-colors">Reformas e Construção</a></li>
        <li><a href="/nichos/estetica"    class="hover:text-white transition-colors">Estética e Beleza</a></li>
        <li><a href="/nichos/professores" class="hover:text-white transition-colors">Professores e Cursos</a></li>
      </ul>
    </div>

    <!-- Cidades + Legal -->
    <div>
      <p class="text-white/70 uppercase text-xs font-medium tracking-wider mb-3">Cidades</p>
      <ul class="space-y-2 mb-6">
        <li><a href="/cidades/santos"       class="hover:text-white transition-colors">Santos</a></li>
        <li><a href="/cidades/guaruja"      class="hover:text-white transition-colors">Guarujá</a></li>
        <li><a href="/cidades/praia-grande" class="hover:text-white transition-colors">Praia Grande</a></li>
        <li><a href="/cidades/sao-vicente"  class="hover:text-white transition-colors">São Vicente</a></li>
      </ul>
      <p class="text-white/70 uppercase text-xs font-medium tracking-wider mb-3">Legal</p>
      <ul class="space-y-2">
        <li><a href="/privacidade" class="hover:text-white transition-colors">Política de Privacidade</a></li>
        <li><a href="/termos"      class="hover:text-white transition-colors">Termos de Uso</a></li>
      </ul>
      <p class="text-white/70 text-xs mt-6">
        contato@marvinsites.com.br
      </p>
    </div>

  </div>

  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-white/60">
      <span>© {ano} Marvin Sites. Todos os direitos reservados.</span>
      <span>Feito com Astro + Tailwind · Hospedado no Netlify</span>
    </div>
  </div>
</footer>
